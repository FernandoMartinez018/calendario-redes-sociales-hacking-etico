# Copia este archivo a .env y rellena los valores reales.

# Clave de Groq (https://console.groq.com/keys)
GROQ_API_KEY=""
# Modelo de Groq a usar (opcional)
GROQ_MODEL="llama-3.3-70b-versatile"

# Cloudinary (multimedia) - https://cloudinary.com/console/settings/api-keys
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# YouTube Data API v3 (métricas reales). Gratis: Google Cloud Console →
# habilita "YouTube Data API v3" → Credenciales → API key.
YOUTUBE_API_KEY=""

# URL base de la app (para el enlace del correo de reset).
APP_URL="http://localhost:3000"

# EmailJS (envío del correo de reset desde el cliente). https://emailjs.com
# La plantilla debe usar {{link}} en el cuerpo y {{to_email}} como destinatario.
VITE_EMAILJS_SERVICE_ID=""
VITE_EMAILJS_TEMPLATE_ID=""
VITE_EMAILJS_PUBLIC_KEY=""
# Plantilla aparte para el correo de bienvenida al registrarse.
VITE_EMAILJS_WELCOME_TEMPLATE_ID=""
